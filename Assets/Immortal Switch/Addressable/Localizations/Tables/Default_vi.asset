  - m_Id: 2500489980461088
    m_Localized: "Anh H\xF9ng Huy\u1EC1n Tho\u1EA1i Ng\u1EABu Nhi\xEAn"
    m_Metadata:
      m_Items: []
  - m_Id: 2500489980461089
    m_Localized: "Trang B\u1ECB SS Ng\u1EABu Nhi\xEAn"
    m_Metadata:
      m_Items: []
  - m_Id: 2500489980461090
    m_Localized: "K\u1EF9 N\u0103ng SS Ng\u1EABu Nhi\xEAn"
    m_Metadata:
      m_Items: []
  - m_Id: 2500489984655360
    m_Localized: "Ti\u1EC1n t\u1EC7 ph\u1ED5 th\xF4ng d\xF9ng \u0111\u1EC3 n\xE2ng
      c\u1EA5p anh h\xF9ng, trang b\u1ECB v\xE0 mua v\u1EADt ph\u1EA9m th\u01B0\u1EDDng"
    m_Metadata:
      m_Items: []
  - m_Id: 2500489984655361
    m_Localized: "Ti\u1EC1n t\u1EC7 cao c\u1EA5p d\xF9ng cho tri\u1EC7u h\u1ED3i
      \u0111\u1EB7c bi\u1EC7t v\xE0 C\u1EEDa H\xE0ng Gi\u1EDBi H\u1EA1n"
    m_Metadata:
      m_Items: []
  - m_Id: 2500489984655362
    m_Localized: "Ti\u1EC1n t\u1EC7 cao c\u1EA5p d\xF9ng \u0111\u1EC3 tri\u1EC7u
      h\u1ED3i, mua v\u1EADt ph\u1EA9m hi\u1EBFm v\xE0 t\u0103ng t\u1ED1c ti\u1EBFn
      tr\xECnh"
    m_Metadata:
      m_Items: []
  - m_Id: 2500489984655363
    m_Localized: "D\xF9ng \u0111\u1EC3 tham gia h\u1EA7m ng\u1EE5c, khi\xEAu chi\u1EBFn
      Boss v\xE0 c\xE1c ho\u1EA1t \u0111\u1ED9ng \u0111\u1EB7c bi\u1EC7t"
    m_Metadata:
      m_Items: []
  - m_Id: 2500489984655364
    m_Localized: "Nh\u1EADn t\u1EEB Arena PvP v\xE0 d\xF9ng trong C\u1EEDa H\xE0ng
      Arena"
    m_Metadata:
      m_Items: []
  - m_Id: 2500489984655365
    m_Localized: "Nh\u1EADn t\u1EEB Guild Boss v\xE0 Guild Event, d\xF9ng trong C\u1EEDa
      H\xE0ng Bang H\u1ED9i"
    m_Metadata:
      m_Items: []
  - m_Id: 2500489984655366
    m_Localized: "Token gi\u1EDBi h\u1EA1n th\u1EDDi gian d\xF9ng \u0111\u1EC3 \u0111\u1ED5i
      th\u01B0\u1EDFng trong C\u1EEDa H\xE0ng S\u1EF1 Ki\u1EC7n"
    m_Metadata:
      m_Items: []
  - m_Id: 2500489984655367
    m_Localized: "D\xF9ng \u0111\u1EC3 tri\u1EC7u h\u1ED3i anh h\xF9ng trong banner
      th\u01B0\u1EDDng"
    m_Metadata:
      m_Items: []
  - m_Id: 2500489984655368
    m_Localized: "D\xF9ng \u0111\u1EC3 t\u0103ng c\u1EA5p anh h\xF9ng"
